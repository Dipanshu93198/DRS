# Database Configuration
# For local development with PostgreSQL
database_url=postgresql://postgres:postgres@localhost/resilience_hub
sqlalchemy_database_url=postgresql+psycopg2://postgres:postgres@localhost/resilience_hub

# API Configuration
api_title=Resilience Hub - Resource Coordination System
api_version=1.0.0

# CORS Configuration
cors_origins=["http://localhost:8080", "http://localhost:3000", "http://localhost:5173"]

# Server Configuration
server_host=0.0.0.0
server_port=8000

# OpenAI Configuration (Phase 4)
openai_api_key=sk-YOUR-API-KEY-HERE
openai_model=gpt-4
openai_temperature=0.7

# OpenWeather Configuration
openweather_api_key=YOUR-OPENWEATHER-API-KEY-HERE
OPENAI_MAX_TOKENS=2000

# Google Sign-In (Backend token audience verification)
# Use the same Web client ID as frontend VITE_GOOGLE_CLIENT_ID
google_client_id=YOUR_GOOGLE_WEB_CLIENT_ID_HERE

# Government / Public data feeds
# India OGD: https://data.gov.in (get API key + choose a resource id)
data_gov_in_api_key=YOUR_DATA_GOV_IN_API_KEY
data_gov_in_resource_id=

# NASA Open APIs: https://api.nasa.gov/
nasa_api_key=DEMO_KEY
nasa_firms_api_key=
nasa_eonet_feed_url=https://eonet.gsfc.nasa.gov/api/v3/events?status=open&limit=50

# Optional user-agent for US weather.gov APIs (if you integrate them)
weather_gov_user_agent=drs-resilience-hub/1.0 (contact@example.com)

# NOAA Climate Data Online (optional)
noaa_api_token=
noaa_dataset_id=
noaa_location_id=

# India official APIs (if available via your org access)
imd_api_key=
ndma_api_key=

# SMS Alert provider
# mock | twilio
sms_provider=mock
twilio_account_sid=
twilio_auth_token=
twilio_from_number=

# Feed URL overrides (defaults are already set in config.py)
usgs_geojson_feed_url=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_day.geojson
openfema_disaster_feed_url=https://www.fema.gov/api/open/v2/DisasterDeclarationsSummaries?$top=50
sachet_ndma_feed_url=https://sachet.ndma.gov.in/
